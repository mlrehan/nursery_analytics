# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=nursery
POSTGRES_PASSWORD=nursery_dev_pw
POSTGRES_DB=nursery_analytics
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Host port the Docker Postgres is published on (so it won't clash with a local
# Postgres on 5432). Connect from pgAdmin on your machine at: localhost:5498
POSTGRES_HOST_PORT=5498

# SQLAlchemy async URL (built from the above in config.py; override only if needed)
# DATABASE_URL=postgresql+asyncpg://nursery:nursery_dev_pw@db:5432/nursery_analytics

# ─── Security ────────────────────────────────────────────────────────────────
# Generate a strong key for production:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_dev_only_super_secret_key_0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Seed admin (created by the seed migration / bootstrap) ───────────────────
ADMIN_EMAIL=admin@lait.org.uk
ADMIN_PASSWORD=Admin123!

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RUN_MIGRATIONS_ON_STARTUP=true
SEED_ON_STARTUP=true

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
