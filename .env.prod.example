# ─── PRODUCTION environment ──────────────────────────────────────────────────
# Copy to .env.prod and change EVERY secret before deploying.

# Database (use a strong password)
POSTGRES_USER=nursery
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=nursery_analytics
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Host ports (coexist with software already on the server) ─────────────────
# Browse the app at http://SERVER_IP:8080 (and/or put a host NGINX in front on 80).
FRONTEND_HOST_PORT=8080
# Postgres is published on this port on ALL interfaces, so you can connect from a
# remote machine / pgAdmin (host: SERVER_IP, port: 15432). Keep a strong password
# and a firewall. (To restrict to the server only, see the note in docker-compose.prod.yml.)
DB_HOST_PORT=15432

# Security — MUST regenerate:  openssl rand -hex 32
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# First admin (created only if you run the seed/bootstrap step)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# App
ENVIRONMENT=production
# Your public URL — used to build absolute links for social share previews (OG image).
# Set this to the exact https address users reach the app on (no trailing slash).
PUBLIC_BASE_URL=https://nursery.yourdomain.co.uk
# true  -> the backend creates/upgrades the database schema automatically on `up`.
RUN_MIGRATIONS_ON_STARTUP=true
# true  -> also load demo data (admin + demo users + sample nursery data) on `up`,
#          so you can log in immediately. Set to false for a clean production start
#          (then create your admin with the one-shot `init` job — see DEPLOYMENT.md).
SEED_ON_STARTUP=false
# Same-origin via nginx, so CORS can be left empty (or set your domain if calling cross-origin)
BACKEND_CORS_ORIGINS=
